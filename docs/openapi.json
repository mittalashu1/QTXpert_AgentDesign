        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid",
            "title": "Project Id"
          },
          "title": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1,
            "title": "Title"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "title",
          "content"
        ],
        "title": "DirectPromptRequest"
      },
      "ExportRequest": {
        "properties": {
          "generation_run_id": {
            "type": "string",
            "format": "uuid",
            "title": "Generation Run Id"
          },
          "format": {
            "type": "string",
            "title": "Format",
            "description": "One of: json, csv, excel, markdown, testrail, zephyr, xray, azure_devops"
          }
        },
        "type": "object",
        "required": [
          "generation_run_id",
          "format"
        ],
        "title": "ExportRequest"
      },
