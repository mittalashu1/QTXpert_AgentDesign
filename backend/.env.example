# ---------------------------------------------------------------------------
# QTXpert.ai Test Design Agent - environment configuration template
# Copy to .env for local development. In Render, set these as real
# environment variables / secrets instead of committing a .env file.
# ---------------------------------------------------------------------------

# General
APP_NAME=QTXpert.ai Test Design Agent
APP_ENV=local
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
POSTGRES_URL=postgresql+asyncpg://qtxpert:qtxpert@localhost:5432/qtxpert
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Microsoft Entra ID (optional SSO)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# LLM provider selection - one of: azure_openai, openai, anthropic, gemini, bedrock
LLM_PROVIDER=azure_openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

OPENAI_API_KEY=

AZURE_OPENAI_API_KEY=
AZURE_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

ANTHROPIC_API_KEY=

GOOGLE_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Vector database (modular; leave provider=none to disable)
VECTOR_DB_PROVIDER=none
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=qtxpert-requirements

# Jira integration (OAuth2)
JIRA_URL=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=

# Confluence integration (OAuth2)
CONFLUENCE_URL=
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=

# File upload
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,md,json,csv
UPLOAD_STORAGE_PATH=./storage/uploads

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
